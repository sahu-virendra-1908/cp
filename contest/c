#include <bits/stdc++.h>
using namespace std;

int main() {
    int t;
    cin >> t;
    while (t--) {
        int n;
        cin >> n;
        vector<int> p(n);
        for (int i = 0; i < n; i++) cin >> p[i];

        for (int i = 0; i < n; i++) {
            int x = p[i];
            int ans = 2 * min(x, n - x + 1) - 1;
            cout << ans << " ";
        }
        cout << endl;
    }
}